#!/bin/bash
# Git pre-push hook to run linting and tests before pushing

set -e

echo "🔍 Running pre-push checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if we're in the right directory
if [ ! -f "pyproject.toml" ]; then
    echo -e "${RED}Error: pyproject.toml not found. Are you in the project root?${NC}"
    exit 1
fi

# Step 1: Run linter
echo -e "${YELLOW}Step 1: Running linter (ruff check)...${NC}"
if ! ruff check app tests; then
    echo -e "${RED}❌ Linter failed! Please fix linting errors before pushing.${NC}"
    echo -e "${YELLOW}Run: ruff check --fix app tests${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Linter passed${NC}"
echo ""

# Step 2: Check code formatting
echo -e "${YELLOW}Step 2: Checking code formatting (ruff format)...${NC}"
if ! ruff format --check app tests; then
    echo -e "${RED}❌ Code formatting check failed!${NC}"
    echo -e "${YELLOW}Run: ruff format app tests${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Code formatting check passed${NC}"
echo ""

# Step 3: Run type checker (non-blocking)
echo -e "${YELLOW}Step 3: Running type checker (mypy)...${NC}"
if mypy app 2>&1 | tee /tmp/mypy_output.log; then
    echo -e "${GREEN}✅ Type checker passed${NC}"
else
    ERROR_COUNT=$(grep -c "error:" /tmp/mypy_output.log 2>/dev/null || echo "0")
    if [ "$ERROR_COUNT" -gt 0 ]; then
        echo -e "${YELLOW}⚠️  Type checker found $ERROR_COUNT issues (non-blocking)${NC}"
        echo -e "${YELLOW}💡 These are mostly from optional cloud dependencies and SQLAlchemy${NC}"
        echo -e "${YELLOW}💡 CI will also show these warnings but won't fail${NC}"
    else
        echo -e "${GREEN}✅ Type checker passed${NC}"
    fi
fi
rm -f /tmp/mypy_output.log
echo ""

# Step 4: Run unit tests
echo -e "${YELLOW}Step 4: Running unit tests...${NC}"
# Run tests and check for failures (errors are OK)
if pytest tests/unit/ -v --tb=line -q --maxfail=1 2>&1 | tee /tmp/pytest_output.log | grep -q "FAILED"; then
    echo -e "${RED}❌ Unit tests failed!${NC}"
    grep "FAILED" /tmp/pytest_output.log | head -5
    rm -f /tmp/pytest_output.log
    exit 1
fi

# Check if tests passed (errors are warnings, not failures)
PASSED=$(grep -oE "[0-9]+ passed" /tmp/pytest_output.log 2>/dev/null | grep -oE "[0-9]+" || echo "0")
if [ "$PASSED" -gt 0 ]; then
    echo -e "${GREEN}✅ Unit tests: $PASSED passed${NC}"
    ERRORS=$(grep -c "ERROR" /tmp/pytest_output.log 2>/dev/null || echo "0")
    if [ "$ERRORS" -gt 0 ]; then
        echo -e "${YELLOW}⚠️  ($ERRORS errors - may be due to missing database connections)${NC}"
    fi
else
    echo -e "${RED}❌ No tests passed!${NC}"
    rm -f /tmp/pytest_output.log
    exit 1
fi
rm -f /tmp/pytest_output.log
echo ""

# Step 5: Check test coverage (optional)
echo -e "${YELLOW}Step 5: Checking test coverage...${NC}"
COVERAGE=$(pytest tests/unit/ --cov=app --cov-report=term-missing -q 2>&1 | grep "TOTAL" | awk '{print $NF}' | sed 's/%//')
if [ -z "$COVERAGE" ]; then
    echo -e "${YELLOW}⚠️  Could not determine coverage${NC}"
else
    echo -e "${GREEN}✅ Test coverage: ${COVERAGE}%${NC}"
fi
echo ""

echo -e "${GREEN}✅ All pre-push checks passed! Ready to push.${NC}"
exit 0

