#!/bin/bash
# Git pre-push hook to run linting and tests before pushing

set -e

echo "🔍 Running pre-push checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if we're in the right directory
if [ ! -f "pyproject.toml" ]; then
    echo -e "${RED}Error: pyproject.toml not found. Are you in the project root?${NC}"
    exit 1
fi

# Step 1: Run linter
echo -e "${YELLOW}Step 1: Running linter (ruff check)...${NC}"
if ! ruff check app tests; then
    echo -e "${RED}❌ Linter failed! Please fix linting errors before pushing.${NC}"
    echo -e "${YELLOW}Run: ruff check --fix app tests${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Linter passed${NC}"
echo ""

# Step 2: Check code formatting
echo -e "${YELLOW}Step 2: Checking code formatting (ruff format)...${NC}"
if ! ruff format --check app tests; then
    echo -e "${RED}❌ Code formatting check failed!${NC}"
    echo -e "${YELLOW}Run: ruff format app tests${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Code formatting check passed${NC}"
echo ""

# Step 3: Run type checker (optional - can be slow, skip for now)
echo -e "${YELLOW}Step 3: Skipping type checker (mypy) - optional${NC}"
echo -e "${YELLOW}💡 Run 'mypy app' manually if needed${NC}"
echo ""

# Step 4: Run unit tests
echo -e "${YELLOW}Step 4: Running unit tests...${NC}"
# Run tests and capture output
TEST_OUTPUT=$(pytest tests/unit/ -v --tb=line -q 2>&1)
TEST_EXIT_CODE=$?

# Check for actual test failures (not just errors)
if [ $TEST_EXIT_CODE -ne 0 ]; then
    # Count failures vs errors
    FAILURES=$(echo "$TEST_OUTPUT" | grep -c "FAILED" || echo "0")
    ERRORS=$(echo "$TEST_OUTPUT" | grep -c "ERROR" || echo "0")
    
    if [ "$FAILURES" -gt 0 ]; then
        echo -e "${RED}❌ Unit tests failed! ($FAILURES failures)${NC}"
        echo "$TEST_OUTPUT" | grep -A 5 "FAILED" | head -20
        exit 1
    elif [ "$ERRORS" -gt 0 ]; then
        echo -e "${YELLOW}⚠️  Unit tests have errors ($ERRORS errors) but no failures${NC}"
        echo -e "${YELLOW}💡 These may be due to missing database connections in some tests${NC}"
        # Don't fail on errors - they might be expected (e.g., database connection errors in unit tests)
    fi
fi

PASSED=$(echo "$TEST_OUTPUT" | grep -oE "[0-9]+ passed" | grep -oE "[0-9]+" || echo "0")
echo -e "${GREEN}✅ Unit tests: $PASSED passed${NC}"
echo ""

# Step 5: Check test coverage (optional)
echo -e "${YELLOW}Step 5: Checking test coverage...${NC}"
COVERAGE=$(pytest tests/unit/ --cov=app --cov-report=term-missing -q 2>&1 | grep "TOTAL" | awk '{print $NF}' | sed 's/%//')
if [ -z "$COVERAGE" ]; then
    echo -e "${YELLOW}⚠️  Could not determine coverage${NC}"
else
    echo -e "${GREEN}✅ Test coverage: ${COVERAGE}%${NC}"
fi
echo ""

echo -e "${GREEN}✅ All pre-push checks passed! Ready to push.${NC}"
exit 0

