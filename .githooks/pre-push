#!/bin/bash
# Git pre-push hook to run linting and tests before pushing

set -e

# Function to handle errors gracefully
handle_error() {
    echo -e "${RED}❌ Pre-push check failed at: $1${NC}"
    exit 1
}

echo "🔍 Running pre-push checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if we're in the right directory
if [ ! -f "pyproject.toml" ]; then
    echo -e "${RED}Error: pyproject.toml not found. Are you in the project root?${NC}"
    exit 1
fi

# Step 1: Run linter
echo -e "${YELLOW}Step 1: Running linter (ruff check)...${NC}"
if ! ruff check app tests; then
    echo -e "${RED}❌ Linter failed! Please fix linting errors before pushing.${NC}"
    echo -e "${YELLOW}Run: ruff check --fix app tests${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Linter passed${NC}"
echo ""

# Step 2: Check code formatting
echo -e "${YELLOW}Step 2: Checking code formatting (ruff format)...${NC}"
if ! ruff format --check app tests; then
    echo -e "${RED}❌ Code formatting check failed!${NC}"
    echo -e "${YELLOW}Run: ruff format app tests${NC}"
    exit 1
fi
echo -e "${GREEN}✅ Code formatting check passed${NC}"
echo ""

# Step 3: Run type checker (non-blocking)
echo -e "${YELLOW}Step 3: Running type checker (mypy)...${NC}"
# Run mypy but don't fail on errors (non-blocking)
set +e  # Temporarily disable exit on error for this step
MYPY_OUTPUT=$(mypy app 2>&1)
MYPY_EXIT_CODE=$?
set -e  # Re-enable exit on error

if [ $MYPY_EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✅ Type checker passed${NC}"
else
    ERROR_COUNT=$(echo "$MYPY_OUTPUT" | grep -c "error:" || echo "0")
    if [ "$ERROR_COUNT" -gt 0 ]; then
        echo -e "${YELLOW}⚠️  Type checker found $ERROR_COUNT issues (non-blocking)${NC}"
        echo -e "${YELLOW}💡 Most errors are from optional cloud dependencies (boto3, azure, google.cloud)${NC}"
        echo -e "${YELLOW}💡 These are ignored via mypy overrides and won't fail CI${NC}"
        # Show summary line
        echo "$MYPY_OUTPUT" | grep "Found.*error" | tail -1 || true
    else
        echo -e "${GREEN}✅ Type checker passed${NC}"
    fi
fi
echo ""

# Step 4: Run unit tests
echo -e "${YELLOW}Step 4: Running unit tests...${NC}"
# Run tests and capture output
set +e  # Temporarily disable exit on error for test parsing
TEST_OUTPUT=$(pytest tests/unit/ -v --tb=line -q 2>&1)
TEST_EXIT_CODE=$?
set -e  # Re-enable exit on error

# Check for actual test failures (not just errors)
FAILURES=$(echo "$TEST_OUTPUT" | grep -c "FAILED" || echo "0")
ERRORS=$(echo "$TEST_OUTPUT" | grep -c "ERROR" || echo "0")
PASSED_RAW=$(echo "$TEST_OUTPUT" | grep -oE "[0-9]+ passed" | grep -oE "[0-9]+" | head -1 || echo "0")
PASSED=$(echo "$PASSED_RAW" | tr -d '\n' | tr -d ' ')

# Ensure PASSED is a valid integer (default to 0 if empty or invalid)
if [ -z "$PASSED" ] || ! [ "$PASSED" -eq "$PASSED" ] 2>/dev/null; then
    PASSED=0
fi

if [ "$FAILURES" -gt 0 ]; then
    echo -e "${RED}❌ Unit tests failed! ($FAILURES failures)${NC}"
    echo "$TEST_OUTPUT" | grep -A 3 "FAILED" | head -10
    exit 1
elif [ "$ERRORS" -gt 0 ] && [ "$PASSED" -eq 0 ]; then
    echo -e "${RED}❌ No tests passed! ($ERRORS errors)${NC}"
    echo "$TEST_OUTPUT" | tail -10
    exit 1
elif [ "$PASSED" -gt 0 ]; then
    echo -e "${GREEN}✅ Unit tests: $PASSED passed${NC}"
    if [ "$ERRORS" -gt 0 ]; then
        echo -e "${YELLOW}⚠️  ($ERRORS errors - may be due to missing database connections)${NC}"
    fi
else
    echo -e "${RED}❌ No tests passed!${NC}"
    exit 1
fi
echo ""

# Step 5: Check test coverage (optional)
echo -e "${YELLOW}Step 5: Checking test coverage...${NC}"
COVERAGE=$(pytest tests/unit/ --cov=app --cov-report=term-missing -q 2>&1 | grep "TOTAL" | awk '{print $NF}' | sed 's/%//')
if [ -z "$COVERAGE" ]; then
    echo -e "${YELLOW}⚠️  Could not determine coverage${NC}"
else
    echo -e "${GREEN}✅ Test coverage: ${COVERAGE}%${NC}"
fi
echo ""

echo -e "${GREEN}✅ All pre-push checks passed! Ready to push.${NC}"
exit 0

