# -----------------------------------------------------------------------------
# Import/Export Orchestrator - Terraform Configuration Example
# -----------------------------------------------------------------------------
# Copy this to terraform.tfvars for local development, or set as
# TERRAFORM_TFVARS secret in GitHub for CI/CD.
# -----------------------------------------------------------------------------

# General
company_prefix = "saasdog"
environment    = "dev"
aws_region     = "us-east-1"
app_name       = "import-export"

# -----------------------------------------------------------------------------
# Shared Infrastructure References
# -----------------------------------------------------------------------------
# These values come from the shared-infrastructure project outputs.
# Run `terraform output` in shared-infrastructure to get these values.

shared_vpc_id              = "vpc-xxxxxxxxx"
shared_public_subnet_ids   = ["subnet-xxx", "subnet-yyy"]
shared_private_subnet_ids  = ["subnet-aaa", "subnet-bbb"]
shared_ecs_cluster_arn     = "arn:aws:ecs:us-east-1:ACCOUNT:cluster/saasdog-shared-ecs-dev"
shared_ecs_cluster_name    = "saasdog-shared-ecs-dev"
shared_rds_endpoint        = "saasdog-shared-rds-dev.xxx.us-east-1.rds.amazonaws.com:5432"
shared_rds_address         = "saasdog-shared-rds-dev.xxx.us-east-1.rds.amazonaws.com"
shared_rds_security_group_id = "sg-xxxxxxxxx"
shared_rds_master_password_secret_arn = "arn:aws:secretsmanager:us-east-1:ACCOUNT:secret:saasdog-shared-rds-master-password-dev-xxxxx"

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

db_name     = "job_runner"
db_username = "job_runner"

# ECS
ecs_task_cpu      = 512    # 0.5 vCPU
ecs_task_memory   = 1024   # 1 GB
ecs_desired_count = 1

# SQS
sqs_visibility_timeout = 300  # 5 minutes
sqs_max_receive_count  = 3

# CloudWatch
log_retention_days = 30

# CORS
allowed_origins = ["http://localhost:3000", "http://localhost:5173"]

# CI/CD (GitHub repository for OIDC trust)
github_repository = "your-org/import-export-orchestrator"

# Feature flags
enable_deletion_protection = false
enable_ui                  = true
