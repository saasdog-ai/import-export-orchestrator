# Terraform Variables Example
# Copy this file to terraform.tfvars and customize for your environment
# NEVER commit terraform.tfvars to version control

aws_region              = "us-east-1"
environment             = "dev"
project_name            = "import-export-orchestrator"
vpc_cidr                = "10.0.0.0/16"
database_instance_class = "db.t3.micro"
database_allocated_storage = 20
database_name           = "job_runner"
database_username       = "postgres"
# database_password must be provided via environment variable:
# export TF_VAR_database_password="your-secure-password"
# Or use AWS Secrets Manager (recommended for production)

ecs_task_cpu            = 512
ecs_task_memory         = 1024
ecs_desired_count       = 1
container_image         = "your-ecr-repo/import-export-orchestrator:latest"
enable_alb              = true

allowed_cidr_blocks = [
  "0.0.0.0/0"  # Restrict this in production!
]

# S3 Configuration
s3_bucket_name = "exports"  # Will be prefixed with project name and environment

# SQS Configuration
sqs_visibility_timeout = 300      # 5 minutes (should be longer than longest job execution time)
sqs_receive_wait_time  = 20       # Long polling wait time in seconds
sqs_max_receive_count  = 3        # Max retries before moving to DLQ
sqs_message_retention  = 1209600  # 14 days (max). Production: keep at 14 days for debugging

# PostgreSQL Configuration
postgres_version = "15"  # Production: use the latest stable version

# RDS Backup Configuration
rds_backup_retention_period = 7             # Days (0 to disable, max 35). Production: 14-35
rds_backup_window           = "03:00-04:00" # UTC. Choose a low-traffic window
rds_maintenance_window      = "mon:04:00-mon:05:00"  # UTC. Must not overlap backup window

# CloudWatch Configuration
log_retention_days = 1  # Days. Production: 30-90

# CORS Origins
allowed_origins = [
  "http://localhost:3000",
  "http://localhost:5173"
]
# Production: replace with your actual domain(s)
# allowed_origins = ["https://app.yourdomain.com"]

# HTTPS / TLS (optional)
# Provide an ACM certificate ARN to enable HTTPS on the ALB
# When set, HTTP traffic is automatically redirected to HTTPS
acm_certificate_arn = ""
# Production: acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/abc-123"

# GitHub OIDC (for CI/CD)
# github_repository = "your-org/import-export-orchestrator"

common_tags = {
  Project     = "import-export-orchestrator"
  ManagedBy   = "terraform"
  Environment = "dev"
  Owner       = "devops"
}
