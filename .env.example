# Application
APP_NAME=import-export-orchestrator
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_runner
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Security (for future JWT implementation)
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# Job Runner
JOB_RUNNER_MAX_WORKERS=5
JOB_RUNNER_QUEUE_SIZE=100

# AWS (for production - use IAM roles instead of static credentials)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=  # Never commit this
# AWS_SECRET_ACCESS_KEY=  # Never commit this

# RDS (for production - use AWS Secrets Manager)
# RDS_HOST=
# RDS_PORT=5432
# RDS_DB_NAME=job_runner
# RDS_USERNAME=
# RDS_PASSWORD=

